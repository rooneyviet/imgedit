SUPABASE_SITE_URL=http://localhost:3000
SUPABASE_AUTH_EXTERNAL_URL=http://localhost:9999
VITE_SUPABASE_AUTH_URL=http://localhost:9999
# Generate strong values (run twice): `openssl rand -hex 32`
SUPABASE_JWT_SECRET=super-secret-jwt-token-min-32-characters
SUPABASE_JWT_EXPIRY=3600
SUPABASE_PG_META_CRYPTO_KEY=replace-with-a-32-char-min-secret
SUPABASE_ENABLE_EMAIL_AUTOCONFIRM=false
SUPABASE_ENABLE_EMAIL_SIGNUP=true
SUPABASE_ENABLE_ANON_USERS=false
SUPABASE_DISABLE_SIGNUP=false
SUPABASE_ADDITIONAL_REDIRECT_URLS=
SUPABASE_SMTP_ADMIN_EMAIL=admin@example.com
SUPABASE_SMTP_HOST=
