SUPABASE_SMTP_USER=
SUPABASE_SMTP_PASS=
SUPABASE_SMTP_SENDER_NAME=
SUPABASE_MAILER_URLPATHS_INVITE=/auth/v1/verify
SUPABASE_MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
SUPABASE_MAILER_URLPATHS_RECOVERY=/auth/v1/verify
SUPABASE_MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
SUPABASE_PGRST_DB_SCHEMAS=public
SUPABASE_PGRST_DB_MAX_ROWS=1000
SUPABASE_PGRST_DB_EXTRA_SEARCH_PATH=public
SUPABASE_STUDIO_DEFAULT_ORGANIZATION=Local
SUPABASE_STUDIO_DEFAULT_PROJECT=imgedit
SUPABASE_URL=http://supabase-auth:9999
SUPABASE_PUBLIC_URL=http://localhost:9999
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

